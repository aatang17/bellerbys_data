# Copy to .env and fill in your keys. Do not commit .env.

# Required for offer letter extraction (PDF/image). Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: path to the grades Excel (default: BNBU SAPM - Semester 1 Grades_v2.xlsx in project folder)
# BELLERBYS_GRADES_EXCEL=/path/to/your/grades.xlsx

# Optional: path to SQLite DB (default: offers.db in project folder)
# BELLERBYS_DB=/path/to/offers.db

# Optional: folder for uploaded PDFs/images (default: uploads/ in project folder)
# BELLERBYS_UPLOAD_DIR=/path/to/uploads
